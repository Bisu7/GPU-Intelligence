# Backend Config
PROJECT_NAME="GPU Intelligence"
SECRET_KEY="your-super-secret-key-for-jwt"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_CORS_ORIGINS=["http://localhost:3001","http://127.0.0.1:3001","http://localhost:3000"]

# Database
DATABASE_URL="postgresql://postgres:postgres@db:5432/gpu_intel"

# Redis
REDIS_URL="redis://redis:6379/0"

# GPU Monitoring
MONITOR_INTERVAL=5
USE_SIMULATOR=true
